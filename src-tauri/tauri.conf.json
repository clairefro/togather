{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pair Presence",
  "version": "0.1.0",
  "identifier": "com.pairpresence.widget",
  "build": {
    "frontendDist": "../renderer"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Pair Presence",
        "width": 220,
        "height": 340,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "resources": {
      "../workers": "workers"
    }
  }
}
