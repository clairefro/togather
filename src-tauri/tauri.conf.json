{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "togather",
  "version": "0.1.12",
  "identifier": "com.pairpresence.widget",
  "build": {
    "frontendDist": "../renderer"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "togather",
        "width": 300,
        "height": 520,
        "minWidth": 200,
        "minHeight": 200,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../workers": "workers"
    },
    "externalBin": [
      "binaries/bare-worker"
    ]
  }
}
